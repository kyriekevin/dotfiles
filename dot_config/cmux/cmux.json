{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "app": {
    "appearance": "dark",
    "minimalMode": false,
    "workspaceInheritWorkingDirectory": true
  },
  "sidebar": {
    "branchLayout": "inline",
    "hideAllDetails": false,
    "showWorkspaceDescription": false,
    "showBranchDirectory": false,
    "showPullRequests": false,
    "showPorts": false,
    "showSSH": false,
    "showLog": false,
    "showProgress": false,
    "showCustomMetadata": false,
    "wrapWorkspaceTitles": false
  },
  "sidebarAppearance": {
    "matchTerminalBackground": true,
    "tintColor": "#000000",
    "tintOpacity": 0.0
  },
  "workspaceColors": {
    "indicatorStyle": "leftRail",
    "selectionColor": "#313244"
  },
  "shortcuts": {
    "bindings": {
      "toggleSidebar": ["ctrl+s", "b"],
      "goToWorkspace": ["ctrl+s", "w"],
      "nextSidebarTab": ["ctrl+s", "n"],
      "prevSidebarTab": ["ctrl+s", "p"],
      "newTab": ["ctrl+s", ";"],
      "newSurface": ["ctrl+s", "c"],
      "splitRight": ["ctrl+s", "shift+\\"],
      "splitDown": ["ctrl+s", "-"],
      "focusLeft": ["ctrl+s", "h"],
      "focusDown": ["ctrl+s", "j"],
      "focusUp": ["ctrl+s", "k"],
      "focusRight": ["ctrl+s", "l"],
      "toggleSplitZoom": ["ctrl+s", "m"],
      "equalizeSplits": ["ctrl+s", "="],
      "closeTab": ["ctrl+s", "x"]
    }
  }
}
